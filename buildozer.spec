[app]
title = Oromusix
package.name = oromusix
package.domain = com.birishbire
source.dir = .
source.include_exts = py,png,jpg,kv,mp3

version = 1.0

requirements = python3,kivy

orientation = portrait
fullscreen = 0

android.permissions = READ_EXTERNAL_STORAGE,READ_MEDIA_AUDIO

[buildozer]
log_level = 2
warn_on_root = 1